# 사이트 기본 주소 — canonical URL, sitemap, OG 태그에 사용
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 검색엔진 소유권 확인 (선택) — 등록 시 발급받는 값
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_NAVER_VERIFICATION=

# ── 스튜디오(CMS) ──────────────────────────────────────────
# 스튜디오(/studio) 로그인 비밀번호. 설정해야 스튜디오가 활성화됨.
ADMIN_PASSWORD=

# 발행 백엔드 — 스튜디오에서 발행하면 이 저장소에 MDX 파일이 커밋되고
# Vercel이 자동 재배포한다. (Contents Read/Write 권한의 fine-grained PAT)
GITHUB_TOKEN=
GITHUB_REPO=gomyong/BLOGSITE
GITHUB_BRANCH=main

# ── 편집샵 결제 (Stripe) ────────────────────────────────────
# Stripe 대시보드 → Developers → API keys 의 Secret key.
# 미설정 시 구매 버튼은 "결제 미설정" 안내를 반환(사이트는 정상 동작).
STRIPE_SECRET_KEY=

# ── 회원(로그인) — Supabase ──────────────────────────────────
# tealdot 계정 아래 별도 프로젝트로 생성 (quote 앱과 프로젝트 분리, 계정만 공유).
# 미설정 시 회원 기능은 비활성화되고 사이트는 지금처럼 정적으로 동작한다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 — consent_log/customer_links 기록 등 RLS 우회가 필요한 곳에서만 사용.
# 절대 클라이언트로 노출하지 말 것.
SUPABASE_SERVICE_ROLE_KEY=
